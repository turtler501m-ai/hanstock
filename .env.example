# KIS Open API
KISTOCK_APP_KEY=your_kis_app_key
KISTOCK_APP_SECRET=your_kis_app_secret
KISTOCK_ACCOUNT=12345678

# Execution mode
TRADING_ENV=demo
DRY_RUN=true
ENABLE_LIVE_TRADING=false
REQUIRE_APPROVAL=true

# Trading parameters
SPLIT_N=7
STOP_LOSS_PCT=-15
TAKE_PROFIT=30
RSI_BUY=30
RSI_SELL=70
TOTAL_CAPITAL=10000000
MAX_POSITIONS=3
MAX_SINGLE_WEIGHT=0.30
CASH_BUFFER=0.20
MAX_DAILY_LOSS_PCT=3.0

# Notifications
SLACK_WEBHOOK_URL=
TRADE_DB_PATH=.runtime/trades.sqlite
ACTIVE_MODEL_VERSION=v1
AI_STRATEGY_ENABLED=false
AI_SCORE_WEIGHT=0.40
AI_MIN_MODEL_CONFIDENCE=0.60
AI_REQUIRE_BACKTEST_PASS=true
AI_AUTO_APPROVE=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=20
AI_CANDIDATE_LIMIT=5
BALANCE_FETCH_TIMEOUT_SECONDS=25

# Telegram futures signal collector
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=.runtime/futures_telegram
TELEGRAM_TARGET_CHANNELS=

# KIS overseas futures demo account
KIS_FUTURES_DEMO_APP_KEY=
KIS_FUTURES_DEMO_APP_SECRET=
KIS_FUTURES_DEMO_ACCOUNT=

# KIS overseas futures real account
KIS_FUTURES_REAL_APP_KEY=
KIS_FUTURES_REAL_APP_SECRET=
KIS_FUTURES_REAL_ACCOUNT=

# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true
