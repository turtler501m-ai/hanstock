<?xml version="1.0" encoding="utf-8"?>
<!--
   Sample data extraction rules file; seehttps://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details on how to configure this file.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Keep local EncryptedSharedPreferences safe, do not backup sensitive keys to cloud -->
        <exclude domain="sharedpref" path="secure_tokens.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_tokens.xml"/>
    </device-transfer>
</data-extraction-rules>
